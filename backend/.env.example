# ═══════════════════════════════════════════════════════════
#  Belle Studio — Configurações
#  Copie este arquivo para .env e preencha os valores
# ═══════════════════════════════════════════════════════════

# Porta do servidor (padrão: 3001)
PORT=3001

# Senha de acesso da proprietária no sistema
OWNER_PASSWORD=belle123

# Nome do salão (aparece nas mensagens WhatsApp)
SALON_NAME=Belle Studio

# ── NÚMERO DA PROPRIETÁRIA ──────────────────────────────────
# Recebe alertas de novos agendamentos e lembretes de atendimento
# Formato: DDI + DDD + número (sem +, espaços ou traços)
# Exemplo: (11) 99999-8888 → 5511999998888
OWNER_WHATSAPP=5511999998888

# ── EVOLUTION API (provedor gratuito) ───────────────────────
WHATSAPP_PROVIDER=evolution
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=belle-chave-123
EVOLUTION_INSTANCE=belle-studio

# ── TWILIO (provedor pago — use se preferir) ────────────────
# WHATSAPP_PROVIDER=twilio
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
