# ─────────────────────────────────────────────────────────
#  Belle Studio — Variáveis de Ambiente
#  Copie este arquivo para .env e preencha os valores
# ─────────────────────────────────────────────────────────

# Porta do servidor
PORT=3001

# Senha da proprietária
OWNER_PASSWORD=belle123

# Nome do salão (aparece nas mensagens)
SALON_NAME=Belle Studio

# ─── WHATSAPP ────────────────────────────────────────────
# Provedor: "evolution" (gratuito) ou "twilio" (pago, mais estável)
WHATSAPP_PROVIDER=evolution

# ── Evolution API (gratuito, recomendado Brasil) ─────────
# Instale em: https://github.com/EvolutionAPI/evolution-api
# Ou use a versão cloud: https://evolution-api.com
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=sua-chave-aqui
EVOLUTION_INSTANCE=belle-studio

# ── Twilio (pago, muito confiável) ──────────────────────
# Crie conta em: https://twilio.com
# WhatsApp Sandbox gratuito para testes
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ─── NÚMERO DA PROPRIETÁRIA ──────────────────────────────
# Número que receberá alertas de novos agendamentos
# Formato: 5511999990000 (código país + DDD + número, sem + ou espaços)
OWNER_WHATSAPP=5511999990000
