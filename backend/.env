# ── SERVER ────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── JWT ───────────────────────────────────────────────────────
JWT_SECRET=sua_chave_secreta_muito_segura_aqui
JWT_EXPIRES_IN=7d

# ── SQLITE ────────────────────────────────────────────────────
DB_PATH=./database/belle.db

# ── EMAIL (Nodemailer) ────────────────────────────────────────
# Use Gmail, SendGrid SMTP, Brevo, etc.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=seu_email@gmail.com
SMTP_PASS=sua_senha_de_app_gmail
EMAIL_FROM="Belle Studio 💅 <seu_email@gmail.com>"

# ── WHATSAPP ──────────────────────────────────────────────────
# Escolha UMA das opções abaixo:

# OPÇÃO 1: Twilio WhatsApp API (oficial)
WHATSAPP_PROVIDER=twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# OPÇÃO 2: Evolution API (open-source, popular no Brasil)
# WHATSAPP_PROVIDER=evolution
# EVOLUTION_API_URL=http://localhost:8080
# EVOLUTION_API_KEY=sua_api_key
# EVOLUTION_INSTANCE=belle-studio

# ── OWNER ─────────────────────────────────────────────────────
OWNER_EMAIL=dono@belle.com
OWNER_PASSWORD=belle123
OWNER_NAME=Proprietária Belle Studio

# ── SCHEDULER ─────────────────────────────────────────────────
# Horário de envio dos lembretes automáticos (cron expression)
# Padrão: 8h da manhã todo dia
REMINDER_CRON=0 8 * * *
REMINDER_ADVANCE_HOURS=2
